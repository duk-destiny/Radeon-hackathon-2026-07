{
  "name": "radeon-workbench",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Unified Web Workbench frontend (UI-0 foundation & contract freeze)",
  "scripts": {
    "dev": "vite --config vite.dev.config.ts",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run src/api/client.test.ts src/api/runs.test.ts && vitest run src/api/contract.test.ts && vitest run src/auth/guard.test.tsx",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.8",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@types/react-test-renderer": "^19.1.0",
    "@vitejs/plugin-react": "^4.3.1",
    "happy-dom": "^20.11.1",
    "jsdom": "^25.0.0",
    "react-test-renderer": "^18.3.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.3",
    "vitest": "^3.2.7"
  }
}
