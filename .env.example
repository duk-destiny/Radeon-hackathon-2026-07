# llama.cpp OpenAI-compatible endpoint. Never commit a populated .env file.
LLM_BASE_URL=http://127.0.0.1:8000/v1
# Dedicated embedding endpoint. Keep this separate from the chat endpoint.
EMBEDDING_BASE_URL=http://127.0.0.1:8080/v1
LLM_API_KEY=local-no-key
PROJECTPACK_INTEGRATION_KEY=replace-with-a-stable-32-character-minimum-secret
LLM_MODEL=qwen3.6-office-agent
LLM_TIMEOUT_SECONDS=15

API_HOST=127.0.0.1
API_PORT=9000

PROJECT_ROOT=/workspace/office-agent/data/projects
VECTOR_DB_ROOT=/workspace/office-agent/data/vector_db
SQLITE_PATH=/workspace/office-agent/data/sqlite/projectpack.db
OUTPUT_ROOT=/workspace/office-agent/outputs
LOG_ROOT=/workspace/office-agent/logs

AGENT_MAX_STEPS=8
